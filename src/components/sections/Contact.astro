---
/* Contact / Contacto section - dark background with form and contact info */
import { SITE } from "@/lib/constants";

const formAction = `https://formspree.io/f/${SITE.formspreeId}`;
---

<section id="contacto" class="py-24 bg-brand-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section heading -->
    <div class="text-center mb-16">
      <p class="uppercase text-sm tracking-widest font-semibold text-amber-500 mb-3">
        CONTACTO
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 text-center">
        Empecemos a trabajar juntos
      </h2>
      <p class="text-lg text-slate-300 text-center max-w-2xl mx-auto">
        Contanos sobre tu empresa y te contactamos en menos de 24 horas.
      </p>
    </div>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- Left column: contact form -->
      <div class="fade-in-up lg:col-span-3">
        <form id="contact-form" action={formAction} method="POST" novalidate>
          <!-- Row 1: Nombre + Empresa -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
            <div>
              <label for="contact-name" class="block text-sm font-medium text-slate-300 mb-2">Nombre *</label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                aria-describedby="contact-name-error"
                class="w-full bg-brand-700/50 border border-brand-600/50 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-colors"
              />
              <p id="contact-name-error" class="mt-2 text-sm text-red-300 hidden"></p>
            </div>
            <div>
              <label for="contact-company" class="block text-sm font-medium text-slate-300 mb-2">Empresa *</label>
              <input
                type="text"
                id="contact-company"
                name="company"
                required
                aria-describedby="contact-company-error"
                class="w-full bg-brand-700/50 border border-brand-600/50 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-colors"
              />
              <p id="contact-company-error" class="mt-2 text-sm text-red-300 hidden"></p>
            </div>
          </div>

          <!-- Row 2: Email + Teléfono -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
            <div>
              <label for="contact-email" class="block text-sm font-medium text-slate-300 mb-2">Email *</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                inputmode="email"
                aria-describedby="contact-email-error"
                class="w-full bg-brand-700/50 border border-brand-600/50 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-colors"
              />
              <p id="contact-email-error" class="mt-2 text-sm text-red-300 hidden"></p>
            </div>
            <div>
              <label for="contact-phone" class="block text-sm font-medium text-slate-300 mb-2">Teléfono</label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                aria-describedby="contact-phone-error"
                class="w-full bg-brand-700/50 border border-brand-600/50 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-colors"
              />
              <p id="contact-phone-error" class="mt-2 text-sm text-red-300 hidden"></p>
            </div>
          </div>

          <!-- Mensaje -->
          <div class="mb-6">
            <label for="contact-message" class="block text-sm font-medium text-slate-300 mb-2">Mensaje *</label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="4"
              aria-describedby="contact-message-error"
              class="w-full bg-brand-700/50 border border-brand-600/50 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-colors"
            ></textarea>
            <p id="contact-message-error" class="mt-2 text-sm text-red-300 hidden"></p>
          </div>

          <!-- Hidden subject -->
          <input type="hidden" name="_subject" value="Nueva consulta desde blitzeninsights.com" />

          <div id="contact-form-status" class="mb-6 hidden rounded-lg border px-4 py-3 text-sm" role="status" aria-live="polite"></div>

          <!-- Submit button -->
          <button
            type="submit"
            id="contact-submit"
            class="w-full sm:w-auto bg-amber-500 text-brand-800 font-semibold px-8 py-4 rounded-lg hover:bg-amber-400 transition-colors text-lg cursor-pointer"
          >
            Enviar mensaje
          </button>
        </form>
      </div>

      <!-- Right column: contact info -->
      <div class="fade-in-up lg:col-span-2">
        <div class="space-y-8">

          <!-- Email -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-lg bg-brand-700/50 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="M22 4L12 13 2 4" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-400">Email</p>
              <a href="mailto:paula@blitzeninsights.com" class="text-white font-medium hover:text-amber-400 transition-colors">
                paula@blitzeninsights.com
              </a>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-lg bg-brand-700/50 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-400">Teléfono</p>
              <a href="tel:+541131845820" class="text-white font-medium hover:text-amber-400 transition-colors">
                (011) 3184-5820
              </a>
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-lg bg-brand-700/50 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-amber-500" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-400">WhatsApp</p>
              <a href="https://wa.me/5491131845820?text=Hola!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20los%20servicios%20de%20Blitzen%20Insights." target="_blank" rel="noopener noreferrer" class="text-white font-medium hover:text-amber-400 transition-colors">
                Escribinos por WhatsApp
              </a>
            </div>
          </div>

          <!-- Ubicación -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-lg bg-brand-700/50 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-400">Ubicación</p>
              <p class="text-white font-medium">Buenos Aires, Argentina</p>
            </div>
          </div>

        </div>

        <!-- Response time note -->
        <p class="text-sm text-slate-400 mt-8 border-t border-brand-700 pt-8">
          Respondemos todas las consultas en menos de 24 horas hábiles.
        </p>
      </div>

    </div>
  </div>
</section>

<script is:inline define:vars={{ formAction }}>
  const form = document.querySelector("#contact-form");
  const submitButton = document.querySelector("#contact-submit");
  const statusBox = document.querySelector("#contact-form-status");

  const fields = {
    name: {
      input: document.querySelector("#contact-name"),
      error: document.querySelector("#contact-name-error"),
      validate(value) {
        if (!value.trim()) return "Ingresá tu nombre.";
        if (value.trim().length < 2) return "El nombre es demasiado corto.";
        return "";
      },
    },
    company: {
      input: document.querySelector("#contact-company"),
      error: document.querySelector("#contact-company-error"),
      validate(value) {
        if (!value.trim()) return "Ingresá el nombre de la empresa.";
        if (value.trim().length < 2) return "La empresa es demasiado corta.";
        return "";
      },
    },
    email: {
      input: document.querySelector("#contact-email"),
      error: document.querySelector("#contact-email-error"),
      validate(value) {
        if (!value.trim()) return "Ingresá tu email.";
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(value.trim())) {
          return "Ingresá un email válido.";
        }
        return "";
      },
    },
    phone: {
      input: document.querySelector("#contact-phone"),
      error: document.querySelector("#contact-phone-error"),
      validate(value) {
        const normalized = value.trim();
        if (!normalized) return "";
        if (!/^[+\d\s()\-]{6,}$/.test(normalized)) {
          return "Ingresá un teléfono válido o dejalo vacío.";
        }
        return "";
      },
    },
    message: {
      input: document.querySelector("#contact-message"),
      error: document.querySelector("#contact-message-error"),
      validate(value) {
        if (!value.trim()) return "Contanos brevemente qué necesitás.";
        if (value.trim().length < 10) return "El mensaje es demasiado corto.";
        return "";
      },
    },
  };

  const setFieldError = (field, message) => {
    field.input.setAttribute("aria-invalid", message ? "true" : "false");
    field.input.classList.toggle("border-red-400", Boolean(message));
    field.input.classList.toggle("focus:ring-red-400/40", Boolean(message));
    field.error.textContent = message;
    field.error.classList.toggle("hidden", !message);
  };

  const setStatus = (message, type) => {
    statusBox.textContent = message;
    statusBox.className =
      "mb-6 rounded-lg border px-4 py-3 text-sm";
    statusBox.classList.remove("hidden");
    if (type === "success") {
      statusBox.classList.add("border-emerald-400/40", "bg-emerald-500/10", "text-emerald-200");
      return;
    }
    statusBox.classList.add("border-red-400/40", "bg-red-500/10", "text-red-200");
  };

  const clearStatus = () => {
    statusBox.textContent = "";
    statusBox.classList.add("hidden");
  };

  const validateField = (field) => {
    const message = field.validate(field.input.value);
    setFieldError(field, message);
    return !message;
  };

  Object.values(fields).forEach((field) => {
    field.input?.addEventListener("blur", () => validateField(field));
    field.input?.addEventListener("input", () => {
      if (field.input.getAttribute("aria-invalid") === "true") {
        validateField(field);
      }
      clearStatus();
    });
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    clearStatus();

    const isValid = Object.values(fields).every((field) => validateField(field));
    if (!isValid) {
      setStatus("Revisá los campos marcados antes de enviar.", "error");
      return;
    }

    const originalText = submitButton.textContent;
    submitButton.disabled = true;
    submitButton.textContent = "Enviando...";

    try {
      const response = await fetch(formAction, {
        method: "POST",
        headers: {
          Accept: "application/json",
        },
        body: new FormData(form),
      });

      if (!response.ok) {
        const data = await response.json().catch(() => null);
        const message = data?.errors?.[0]?.message || "No pudimos enviar tu mensaje. Probá de nuevo en unos minutos.";
        throw new Error(message);
      }

      form.reset();
      Object.values(fields).forEach((field) => setFieldError(field, ""));
      setStatus("Mensaje enviado. Te vamos a responder dentro de las próximas 24 horas hábiles.", "success");
    } catch (error) {
      setStatus(error.message || "Ocurrió un error al enviar el formulario.", "error");
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = originalText;
    }
  });
</script>
