---
/* Results / Resultados section - stats counters & testimonials */
---

<section id="resultados" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section heading -->
    <div class="text-center fade-in-up">
      <p class="uppercase text-sm tracking-widest font-semibold text-amber-500 mb-3">
        Resultados
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-16">
        Números que hablan por sí solos
      </h2>
    </div>

    <!-- Stats counters -->
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20 stagger-children"
      data-animate-counters
    >
      <div class="stat-card relative overflow-hidden text-center p-8 rounded-2xl bg-gradient-to-br from-brand-50 to-white border border-brand-100 shadow-sm fade-in-up">
        <p class="text-5xl font-bold text-brand-500 mb-2" data-target="10" data-suffix="+">
          0+
        </p>
        <p class="text-lg text-slate-600">años de experiencia</p>
      </div>

      <div class="stat-card relative overflow-hidden text-center p-8 rounded-2xl bg-gradient-to-br from-brand-50 to-white border border-brand-100 shadow-sm fade-in-up">
        <p class="text-5xl font-bold text-brand-500 mb-2" data-target="200" data-suffix="+">
          0+
        </p>
        <p class="text-lg text-slate-600">empresas transformadas</p>
      </div>

      <div class="stat-card relative overflow-hidden text-center p-8 rounded-2xl bg-gradient-to-br from-brand-50 to-white border border-brand-100 shadow-sm fade-in-up">
        <p class="text-5xl font-bold text-brand-500 mb-2">
          B2B &amp; B2C
        </p>
        <p class="text-lg text-slate-600">alcance multisectorial</p>
      </div>
    </div>

    <!-- Testimonials -->
    <div class="fade-in-up">
      <h3 class="text-2xl font-bold text-slate-900 mb-8 text-center">
        Lo que dicen nuestros clientes
      </h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">

      <!-- Testimonial 1 -->
      <figure class="testimonial-card relative rounded-2xl p-8 bg-white border border-slate-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-amber-300/60 fade-in-up">
        <svg class="absolute top-5 right-6 w-10 h-10 text-amber-400/30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.5 10c-1.93 0-3.5 1.57-3.5 3.5S4.57 17 6.5 17c.28 0 .55-.04.81-.1l-.01.03c-.54 1.35-1.82 2.32-3.3 2.4v2.17c3.54-.1 6-3.04 6-6.5V13c0-1.66-1.34-3-3-3zm11 0c-1.93 0-3.5 1.57-3.5 3.5s1.57 3.5 3.5 3.5c.28 0 .55-.04.81-.1l-.01.03c-.54 1.35-1.82 2.32-3.3 2.4v2.17c3.54-.1 6-3.04 6-6.5V13c0-1.66-1.34-3-3-3z" />
        </svg>
        <blockquote class="relative text-slate-600 italic mb-6 leading-relaxed">
          Blitzen nos ayudó a estructurar un área comercial que antes no
          existía. En 6 meses duplicamos nuestra generación de leads.
        </blockquote>
        <figcaption class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-brand-100 ring-2 ring-white shadow-sm flex items-center justify-center">
            <span class="text-brand-500 font-semibold text-sm">MG</span>
          </div>
          <div>
            <p class="font-semibold text-slate-900 text-sm">María García</p>
            <p class="text-slate-500 text-sm">Directora Comercial, TechCorp</p>
          </div>
        </figcaption>
      </figure>

      <!-- Testimonial 2 -->
      <figure class="testimonial-card relative rounded-2xl p-8 bg-white border border-slate-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-amber-300/60 fade-in-up">
        <svg class="absolute top-5 right-6 w-10 h-10 text-amber-400/30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.5 10c-1.93 0-3.5 1.57-3.5 3.5S4.57 17 6.5 17c.28 0 .55-.04.81-.1l-.01.03c-.54 1.35-1.82 2.32-3.3 2.4v2.17c3.54-.1 6-3.04 6-6.5V13c0-1.66-1.34-3-3-3zm11 0c-1.93 0-3.5 1.57-3.5 3.5s1.57 3.5 3.5 3.5c.28 0 .55-.04.81-.1l-.01.03c-.54 1.35-1.82 2.32-3.3 2.4v2.17c3.54-.1 6-3.04 6-6.5V13c0-1.66-1.34-3-3-3z" />
        </svg>
        <blockquote class="relative text-slate-600 italic mb-6 leading-relaxed">
          La calidad de las bases de datos y la inteligencia de mercado que
          nos proporcionaron fue un diferencial clave para nuestra expansión.
        </blockquote>
        <figcaption class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-brand-100 ring-2 ring-white shadow-sm flex items-center justify-center">
            <span class="text-brand-500 font-semibold text-sm">CR</span>
          </div>
          <div>
            <p class="font-semibold text-slate-900 text-sm">Carlos Rodríguez</p>
            <p class="text-slate-500 text-sm">CEO, InnovaGroup</p>
          </div>
        </figcaption>
      </figure>

      <!-- Testimonial 3 -->
      <figure class="testimonial-card relative rounded-2xl p-8 bg-white border border-slate-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-amber-300/60 fade-in-up">
        <svg class="absolute top-5 right-6 w-10 h-10 text-amber-400/30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.5 10c-1.93 0-3.5 1.57-3.5 3.5S4.57 17 6.5 17c.28 0 .55-.04.81-.1l-.01.03c-.54 1.35-1.82 2.32-3.3 2.4v2.17c3.54-.1 6-3.04 6-6.5V13c0-1.66-1.34-3-3-3zm11 0c-1.93 0-3.5 1.57-3.5 3.5s1.57 3.5 3.5 3.5c.28 0 .55-.04.81-.1l-.01.03c-.54 1.35-1.82 2.32-3.3 2.4v2.17c3.54-.1 6-3.04 6-6.5V13c0-1.66-1.34-3-3-3z" />
        </svg>
        <blockquote class="relative text-slate-600 italic mb-6 leading-relaxed">
          No son consultores que entregan un PDF y desaparecen. Se
          involucran, miden y ajustan. Eso marca la diferencia.
        </blockquote>
        <figcaption class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-brand-100 ring-2 ring-white shadow-sm flex items-center justify-center">
            <span class="text-brand-500 font-semibold text-sm">LM</span>
          </div>
          <div>
            <p class="font-semibold text-slate-900 text-sm">Laura Méndez</p>
            <p class="text-slate-500 text-sm">VP de Ventas, SureScale</p>
          </div>
        </figcaption>
      </figure>

    </div>
  </div>
</section>

<style>
  .stat-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 1.5rem;
    right: 1.5rem;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--color-amber-500), transparent);
    opacity: 0.7;
  }
</style>

<!-- Counter animation script -->
<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const counters = entry.target.querySelectorAll('[data-target]');
      counters.forEach(counter => {
        const target = parseInt(counter.getAttribute('data-target') || '0');
        const suffix = counter.getAttribute('data-suffix') || '';
        let current = 0;
        const increment = target / 60;
        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            current = target;
            clearInterval(timer);
          }
          counter.textContent = Math.floor(current) + suffix;
        }, 16);
      });
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.3 });

const statsSection = document.querySelector('[data-animate-counters]');
if (statsSection) observer.observe(statsSection);
</script>
