---
export interface Props {
  title: string;
  description: string;
  icon: string;
  dark?: boolean;
  class?: string;
}

const {
  title,
  description,
  icon,
  dark = false,
  class: className,
} = Astro.props;

const iconColor = dark ? 'text-brand-400' : 'text-brand-500';
const iconBg = dark ? 'bg-brand-600/20' : 'bg-brand-50';
---

<div
  class:list={[
    'rounded-xl p-6 md:p-8 transition-all duration-200',
    dark
      ? 'bg-brand-700/50 border border-brand-600/30 hover:border-brand-500/50'
      : 'bg-white border border-slate-200 shadow-sm hover:shadow-md hover:-translate-y-1',
    className,
  ]}
>
  {/* ── Icon ── */}
  <div class:list={['w-12 h-12 rounded-lg flex items-center justify-center mb-4', iconBg]}>
    <span class={iconColor}>
      {icon === 'strategy' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <circle cx="12" cy="12" r="6" />
          <circle cx="12" cy="12" r="2" />
          <line x1="12" y1="2" x2="12" y2="6" />
          <line x1="12" y1="18" x2="12" y2="22" />
          <line x1="2" y1="12" x2="6" y2="12" />
          <line x1="18" y1="12" x2="22" y2="12" />
        </svg>
      )}

      {icon === 'data' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="12" width="4" height="9" rx="1" />
          <rect x="10" y="7" width="4" height="14" rx="1" />
          <rect x="17" y="3" width="4" height="18" rx="1" />
        </svg>
      )}

      {icon === 'prospecting' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="10" cy="8" r="3" />
          <path d="M6 21v-2a4 4 0 0 1 4-4h1" />
          <circle cx="17" cy="15" r="4" />
          <line x1="20" y1="18" x2="23" y2="21" />
        </svg>
      )}

      {icon === 'diagnostic' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="5" y="2" width="14" height="20" rx="2" />
          <line x1="9" y1="6" x2="15" y2="6" />
          <path d="M9 14l2 2 4-4" />
        </svg>
      )}

      {icon === 'training' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2 10l10-5 10 5-10 5-10-5z" />
          <path d="M22 10v6" />
          <path d="M6 12v5c0 2 3 3 6 3s6-1 6-3v-5" />
        </svg>
      )}

      {icon === 'growth' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
          <polyline points="16 7 22 7 22 13" />
        </svg>
      )}

      {icon === 'investment' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <line x1="12" y1="6" x2="12" y2="18" />
          <path d="M15.5 9.5c0-1.5-1.5-2.5-3.5-2.5s-3.5 1-3.5 2.5 1.5 2.5 3.5 2.5 3.5 1 3.5 2.5-1.5 2.5-3.5 2.5-3.5-1-3.5-2.5" />
        </svg>
      )}

      {icon === 'results' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 12 7s5-3 7.5-3a2.5 2.5 0 0 1 0 5H18" />
          <path d="M8 9h8l-1 12H9L8 9z" />
          <line x1="12" y1="13" x2="12" y2="17" />
        </svg>
      )}

      {icon === 'partners' && (
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M11 17l-1.5 1.5a2.5 2.5 0 0 1-3.5-3.5L9 12" />
          <path d="M13 7l1.5-1.5a2.5 2.5 0 0 1 3.5 3.5L15 12" />
          <path d="M8 12h8" />
          <path d="M2 15l3-3" />
          <path d="M19 12l3-3" />
        </svg>
      )}
    </span>
  </div>

  {/* ── Content ── */}
  <h3 class:list={['text-lg font-semibold mb-2', dark ? 'text-white' : 'text-slate-900']}>
    {title}
  </h3>
  <p class:list={['text-sm leading-relaxed', dark ? 'text-slate-300' : 'text-slate-600']}>
    {description}
  </p>
</div>
