---
export interface Props {
  variant?: 'mark' | 'horizontal' | 'vertical';
  size?: 'sm' | 'md' | 'lg';
  dark?: boolean;
  class?: string;
}

const {
  variant = 'horizontal',
  size = 'md',
  dark = false,
  class: className = '',
} = Astro.props;

const sizeMap = {
  sm: { icon: 24, text: 'text-sm', gap: 'gap-1.5' },
  md: { icon: 36, text: 'text-base', gap: 'gap-2' },
  lg: { icon: 48, text: 'text-lg', gap: 'gap-3' },
};

const s = sizeMap[size];
const textColor = dark ? 'text-white' : 'text-brand-800';
---

<div
  class:list={[
    'inline-flex items-center',
    variant === 'vertical' && 'flex-col',
    variant === 'horizontal' && `flex-row ${s.gap}`,
    className,
  ]}
>
  {/* ── Lighthouse mark ── */}
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 64 64"
    width={s.icon}
    height={s.icon}
    fill="none"
    aria-hidden="true"
  >
    {/* Lighthouse body - trapezoid */}
    <polygon points="24,56 40,56 36,24 28,24" fill="#2563eb" />

    {/* Windows on the body */}
    <rect x="30" y="30" width="4" height="4" rx="0.5" fill="white" opacity="0.85" />
    <rect x="30" y="38" width="4" height="4" rx="0.5" fill="white" opacity="0.85" />
    <rect x="30" y="46" width="4" height="4" rx="0.5" fill="white" opacity="0.85" />

    {/* Lantern room on top */}
    <rect x="27" y="18" width="10" height="6" rx="1" fill="#2563eb" />

    {/* Lantern cap */}
    <polygon points="29,18 35,18 32,14" fill="#2563eb" />

    {/* Light beam line 1 - short, lowest angle */}
    <line x1="37" y1="20" x2="48" y2="16" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" />
    <circle cx="48" cy="16" r="2.5" fill="#f59e0b" />

    {/* Light beam line 2 - medium */}
    <line x1="37" y1="18" x2="52" y2="10" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" />
    <circle cx="52" cy="10" r="2.5" fill="#f59e0b" />

    {/* Light beam line 3 - longest, steepest */}
    <line x1="37" y1="16" x2="56" y2="4" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" />
    <circle cx="56" cy="4" r="2.5" fill="#f59e0b" />

    {/* Base platform */}
    <rect x="22" y="56" width="20" height="3" rx="1" fill="#2563eb" />
  </svg>

  {/* ── Wordmark ── */}
  {variant !== 'mark' && (
    <div
      class:list={[
        'flex leading-tight select-none',
        variant === 'vertical' ? 'flex-col items-center mt-1' : 'flex-row items-baseline',
        s.text,
        textColor,
      ]}
    >
      <span class="font-bold tracking-wide">BLITZEN</span>
      {variant === 'horizontal' && <span class="mx-0.5" />}
      <span class="font-normal tracking-wide">INSIGHTS</span>
    </div>
  )}
</div>
