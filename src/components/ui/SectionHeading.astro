---
export interface Props {
  label: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  dark?: boolean;
  class?: string;
}

const {
  label,
  title,
  description,
  align = 'center',
  dark = false,
  class: className,
} = Astro.props;
---

<div
  class:list={[
    'max-w-3xl',
    align === 'center' && 'mx-auto text-center',
    align === 'left' && 'text-left',
    className,
  ]}
>
  <p class="uppercase text-sm font-semibold tracking-widest text-amber-500 mb-3">
    {label}
  </p>
  <h2
    class:list={[
      'text-3xl md:text-4xl font-bold mb-4',
      dark ? 'text-white' : 'text-slate-900',
    ]}
  >
    {title}
  </h2>
  {description && (
    <p class:list={['text-lg', dark ? 'text-slate-300' : 'text-slate-600']}>
      {description}
    </p>
  )}
</div>
